# ============================================
# PATIKA — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyala: cp .env.example .env.local
# .env.local dosyasını asla git'e commit etme!
# ============================================

# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Anthropic Claude API ---
# NOT: Bu key güvenli sunucuda tutulmalı.
# Client-side kullanım için Supabase Edge Function kullan.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Google Maps ---
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# --- Expo / EAS ---
EXPO_PUBLIC_APP_ENV=development
# Değerler: development | staging | production
